# .dockerignore - Otimização de contexto de build
# Arquivos e diretórios que não devem ser enviados ao Docker daemon

# Git
.git
.gitignore
.gitattributes

# Documentação
*.md
!README.md
LICENSE
CHANGELOG.md
COMMIT_MESSAGE.md
DEPLOY*.md
SQUAD*.md
SPECS*.md
MONITORING.md
SECURITY.md

# Testes
*_test.go
*.test
.coverage
coverage.out
test-results/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Docker
Dockerfile*
docker-compose*.yml
.docker/

# Ambiente local
.env
.env.*
!.env.example
*.local

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~
.windsurf/

# Binários e artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
transprota
main
dist/
build/
bin/

# Banco de dados local
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# Frontend (separado)
frontend/
node_modules/
npm-debug.log
yarn-error.log

# Cache
.cache/
tmp/
temp/

# Sistema operacional
.DS_Store
Thumbs.db
